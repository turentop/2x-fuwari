---
import { Icon } from "astro-icon/components";
import { licenseConfig, profileConfig } from "../../config";

import { formatPostDateForDisplay } from "../../utils/date-utils";

interface Props {
	title: string;
	slug: string;
	pubDate: Date;
	class: string;
}

const { title, pubDate } = Astro.props;
const className = Astro.props.class;
const profileConf = profileConfig;
const licenseConf = licenseConfig;
const postUrl = decodeURIComponent(Astro.url.toString());
---
<div class=`relative transition overflow-hidden bg-[var(--license-block-bg)] py-5 px-6 ${className}`>
    <div class="transition font-bold text-white/75">
        {title}
    </div>

    <a id="current-link" style="display:none;" class="link text-[var(--primary)]"></a>

    <script>
    const currentLink = document.getElementById('current-link');

	if (currentLink) {
	    const url = new URL(window.location.href);
	    const canonicalUrl = `${url.origin}${url.pathname}`;

	    currentLink.textContent = canonicalUrl;
	    currentLink.href = canonicalUrl;
	    currentLink.style.display = 'inline';
	}
    </script>

    <div class="flex gap-6 mt-2">
        <div>
            <div class="transition text-white/30 text-sm">作者</div>
            <div class="transition text-white/75 line-clamp-2">{profileConf.name}</div>
        </div>
        <div>
            <div class="transition text-white/30 text-sm">发布于</div>
            <div class="transition text-white/75 line-clamp-2">{formatPostDateForDisplay(pubDate)}</div>
        </div>
        <div>
            <div class="transition text-white/30 text-sm">许可协议</div>
            <a href={licenseConf.url} target="_blank" class="link text-[var(--primary)] line-clamp-2">{licenseConf.name}</a>
        </div>
    </div>
    <Icon name="creative-commons" class="transition text-[15rem] absolute pointer-events-none right-6 top-1/2 -translate-y-1/2 text-white/5"></Icon>
</div>


